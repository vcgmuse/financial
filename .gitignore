# --- OS Metadata ---
.DS_Store
Thumbs.db
.directory

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Node / Dependencies ---
# (Even if you aren't using them now, this prevents accidental uploads if you add them later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Environment & Secrets ---
# Never upload your API keys or private configs
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Build / Output ---
dist/
build/
out/

# --- Logs ---
logs
*.log

# --- Project Specific ---
# If you keep high-res design assets or backups in the folder
*.psd
*.ai
*.sketch
backup/
echo "*.xcf" >> .gitignore
echo "tesetStyle.css" >> .gitignore